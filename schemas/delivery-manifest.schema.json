{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WangXueZhi/dev-flow-ai/schemas/delivery-manifest.schema.json",
  "title": "DevFlow DeliveryManifest",
  "description": "A machine-readable delivery artifact index and evidence summary generated by dev-flow report.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "artifactsDir", "status", "artifacts", "counts", "evidence"],
  "properties": {
    "version": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "artifactsDir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "sourceDocuments": {
      "$ref": "#/$defs/sourceDocuments"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "counts": {
      "$ref": "#/$defs/counts"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness", "verification", "visual", "sourceChanges"],
      "properties": {
        "readiness": {
          "enum": ["needs attention", "ready for review"]
        },
        "verification": {
          "enum": ["failed", "missing", "passed", "skipped"]
        },
        "visual": {
          "enum": ["failed", "not-run", "passed"]
        },
        "sourceChanges": {
          "enum": ["applied", "not-applied", "unchanged"]
        }
      }
    },
    "sourceDocuments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirementsPath", "uiPath", "apiPath"],
      "properties": {
        "requirementsPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uiPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "apiPath": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "path", "status", "required", "role"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "enum": ["directory", "image", "json", "markdown"]
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["missing", "not-applicable", "present"]
        },
        "required": {
          "type": "boolean"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptanceCriteria",
        "openQuestions",
        "deliveryRisks",
        "highDeliveryRisks",
        "appliedEntries",
        "appliedOperations",
        "touchedFiles",
        "verificationCommands",
        "visualScreenshots",
        "visualLayoutIssues",
        "visualRequiredText",
        "designTokens",
        "apiStateRequirements",
        "reviewerNotes"
      ],
      "properties": {
        "acceptanceCriteria": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "openQuestions": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "deliveryRisks": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "highDeliveryRisks": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "appliedEntries": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "appliedOperations": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "touchedFiles": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "verificationCommands": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualScreenshots": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualLayoutIssues": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualRequiredText": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "designTokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "apiStateRequirements": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "reviewerNotes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      }
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptanceCriteria",
        "verificationCommands",
        "visualScreenshots",
        "visualRequiredText",
        "visualLayoutIssues",
        "designTokens",
        "apiStateRequirements",
        "appliedChanges",
        "deliveryRisks",
        "openQuestions"
      ],
      "properties": {
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/acceptanceEvidence"
          }
        },
        "verificationCommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationCommand"
          }
        },
        "visualScreenshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualScreenshot"
          }
        },
        "visualRequiredText": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualRequiredText"
          }
        },
        "visualLayoutIssues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualLayoutIssue"
          }
        },
        "designTokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/designToken"
          }
        },
        "apiStateRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/apiStateRequirement"
          }
        },
        "appliedChanges": {
          "$ref": "#/$defs/appliedChanges"
        },
        "sourceContext": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceContextEntry"
          }
        },
        "taskChangelog": {
          "$ref": "#/$defs/taskChangelog"
        },
        "deliveryRisks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deliveryRisk"
          }
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "taskChangelog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewHandoff"],
      "properties": {
        "reviewHandoff": {
          "$ref": "#/$defs/taskChangelogReviewHandoff"
        },
        "verificationSummary": {
          "$ref": "#/$defs/taskChangelogVerificationSummary"
        }
      }
    },
    "taskChangelogReviewHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewerNotes"],
      "properties": {
        "executionLogPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verificationReportPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "deliveryReportPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reviewerNotes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "taskChangelogVerificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reportPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "finishedAt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "commandsPassed": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "commands": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "designToken": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "sourceLine", "name", "value", "summary"],
      "properties": {
        "category": {
          "enum": ["color", "iconography", "motion", "other", "radius", "shadow", "spacing", "typography"]
        },
        "sourceLine": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "apiStateRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceLine", "summary"],
      "properties": {
        "sourceLine": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "acceptanceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "status", "evidence", "knownGaps", "assumptions", "manualQa"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["needs attention", "needs evidence", "ready for review"]
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "knownGaps": {
          "$ref": "#/$defs/stringArray"
        },
        "assumptions": {
          "$ref": "#/$defs/stringArray"
        },
        "manualQa": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exitCode", "durationMs"],
      "properties": {
        "command": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "exitCode": {
          "type": ["integer", "null"]
        },
        "durationMs": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "remediation": {
          "type": "string"
        },
        "remediationPlan": {
          "$ref": "#/$defs/verificationRemediationPlan"
        },
        "outputExcerpt": {
          "$ref": "#/$defs/verificationOutputExcerpt"
        }
      }
    },
    "verificationRemediationPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "summary", "nextActions", "artifactReferences"],
      "properties": {
        "category": {
          "enum": ["audit", "build", "e2e", "format", "general", "imports", "lint", "test", "typecheck"]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "nextActions": {
          "$ref": "#/$defs/stringArray"
        },
        "artifactReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/remediationArtifactReference"
          }
        }
      }
    },
    "remediationArtifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "path"],
      "properties": {
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "verificationOutputExcerpt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "truncatedStdout": {
          "type": "boolean"
        },
        "truncatedStderr": {
          "type": "boolean"
        }
      }
    },
    "visualScreenshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewport", "width", "height", "path"],
      "properties": {
        "viewport": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "blank": {
          "type": "boolean"
        },
        "distinctPixelRatio": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "visualRequiredText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "found"],
      "properties": {
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "found": {
          "type": "boolean"
        }
      }
    },
    "visualLayoutIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewport", "width", "height", "type", "selector", "message"],
      "properties": {
        "viewport": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "type": {
          "enum": ["clipped-text", "horizontal-overflow", "overlap"]
        },
        "selector": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "message": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "appliedChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "touchedFiles", "operations", "lineDelta", "backupManifestPaths", "operationDetails"],
      "properties": {
        "entries": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "touchedFiles": {
          "$ref": "#/$defs/stringArray"
        },
        "operations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "written", "deleted", "unchanged"],
          "properties": {
            "total": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "written": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "deleted": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "unchanged": {
              "$ref": "#/$defs/nonNegativeInteger"
            }
          }
        },
        "lineDelta": {
          "type": "integer"
        },
        "backupManifestPaths": {
          "$ref": "#/$defs/stringArray"
        },
        "operationDetails": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/appliedChangeOperation"
          }
        }
      }
    },
    "appliedChangeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "summary", "appliedAt", "entryStatus", "type", "path", "status", "bytesWritten"],
      "properties": {
        "taskId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "appliedAt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "entryStatus": {
          "enum": ["applied", "unchanged"]
        },
        "type": {
          "enum": ["delete", "replace", "write"]
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["deleted", "unchanged", "written"]
        },
        "bytesWritten": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "replacements": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "linesBefore": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "linesAfter": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "lineDelta": {
          "type": "integer"
        },
        "backupManifestPath": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "sourceContextEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedAt", "mode", "taskId", "entries", "omitted", "limits"],
      "properties": {
        "generatedAt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "mode": {
          "enum": ["apply", "dry-run"]
        },
        "taskId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "unit": {
          "$ref": "#/$defs/sourceContextUnit"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceContextSample"
          }
        },
        "omitted": {
          "$ref": "#/$defs/stringArray"
        },
        "limits": {
          "$ref": "#/$defs/sourceContextLimits"
        }
      }
    },
    "sourceContextUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "sourceContextSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["binary", "directory", "file", "glob", "missing"]
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sizeBytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "sourceContextLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxEntries", "maxFileBytes", "maxTotalBytes", "maxDirectoryEntries"],
      "properties": {
        "maxEntries": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "maxFileBytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "maxTotalBytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "maxDirectoryEntries": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      }
    },
    "deliveryRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "source", "summary", "recommendation"],
      "properties": {
        "level": {
          "enum": ["high", "low", "medium"]
        },
        "source": {
          "enum": ["api", "repository", "requirements", "ui"]
        },
        "sourceLine": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "recommendation": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
