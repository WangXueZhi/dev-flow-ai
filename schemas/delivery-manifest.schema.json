{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WangXueZhi/dev-flow-ai/schemas/delivery-manifest.schema.json",
  "title": "DevFlow DeliveryManifest",
  "description": "A machine-readable delivery artifact index and evidence summary generated by dev-flow report.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "artifactsDir", "status", "artifacts", "counts", "evidence"],
  "properties": {
    "version": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "artifactsDir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "sourceDocuments": {
      "$ref": "#/$defs/sourceDocuments"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "counts": {
      "$ref": "#/$defs/counts"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness", "verification", "visual", "sourceChanges"],
      "properties": {
        "readiness": {
          "enum": ["needs attention", "ready for review"]
        },
        "verification": {
          "enum": ["failed", "missing", "passed", "skipped"]
        },
        "visual": {
          "enum": ["failed", "not-run", "passed"]
        },
        "sourceChanges": {
          "enum": ["applied", "not-applied", "unchanged"]
        }
      }
    },
    "sourceDocuments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirementsPath", "uiPath", "apiPath"],
      "properties": {
        "requirementsPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uiPath": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "apiPath": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "path", "status", "required", "role"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "enum": ["directory", "image", "json", "markdown"]
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["missing", "not-applicable", "present"]
        },
        "required": {
          "type": "boolean"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptanceCriteria",
        "openQuestions",
        "deliveryRisks",
        "highDeliveryRisks",
        "appliedEntries",
        "appliedOperations",
        "touchedFiles",
        "verificationCommands",
        "visualScreenshots",
        "visualLayoutIssues",
        "visualRequiredText"
      ],
      "properties": {
        "acceptanceCriteria": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "openQuestions": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "deliveryRisks": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "highDeliveryRisks": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "appliedEntries": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "appliedOperations": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "touchedFiles": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "verificationCommands": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualScreenshots": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualLayoutIssues": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visualRequiredText": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      }
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptanceCriteria",
        "verificationCommands",
        "visualScreenshots",
        "visualRequiredText",
        "appliedChanges",
        "deliveryRisks",
        "openQuestions"
      ],
      "properties": {
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/acceptanceEvidence"
          }
        },
        "verificationCommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationCommand"
          }
        },
        "visualScreenshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualScreenshot"
          }
        },
        "visualRequiredText": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualRequiredText"
          }
        },
        "appliedChanges": {
          "$ref": "#/$defs/appliedChanges"
        },
        "deliveryRisks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deliveryRisk"
          }
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptanceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "status", "evidence", "knownGaps", "assumptions", "manualQa"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["needs attention", "needs evidence", "ready for review"]
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "knownGaps": {
          "$ref": "#/$defs/stringArray"
        },
        "assumptions": {
          "$ref": "#/$defs/stringArray"
        },
        "manualQa": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exitCode", "durationMs"],
      "properties": {
        "command": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "exitCode": {
          "type": ["integer", "null"]
        },
        "durationMs": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      }
    },
    "visualScreenshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewport", "width", "height", "path"],
      "properties": {
        "viewport": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "blank": {
          "type": "boolean"
        },
        "distinctPixelRatio": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "visualRequiredText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "found"],
      "properties": {
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "found": {
          "type": "boolean"
        }
      }
    },
    "appliedChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "touchedFiles", "operations", "lineDelta", "backupManifestPaths"],
      "properties": {
        "entries": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "touchedFiles": {
          "$ref": "#/$defs/stringArray"
        },
        "operations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "written", "deleted", "unchanged"],
          "properties": {
            "total": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "written": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "deleted": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "unchanged": {
              "$ref": "#/$defs/nonNegativeInteger"
            }
          }
        },
        "lineDelta": {
          "type": "integer"
        },
        "backupManifestPaths": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "deliveryRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "source", "summary", "recommendation"],
      "properties": {
        "level": {
          "enum": ["high", "low", "medium"]
        },
        "source": {
          "enum": ["api", "repository", "requirements", "ui"]
        },
        "sourceLine": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "recommendation": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
