{
  "name": "dev-flow-ai",
  "version": "0.1.0",
  "description": "AI workflow CLI for turning frontend requirements, UI notes, and API docs into implementation plans and delivery artifacts.",
  "type": "module",
  "bin": {
    "dev-flow": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WangXueZhi/dev-flow-ai.git"
  },
  "bugs": {
    "url": "https://github.com/WangXueZhi/dev-flow-ai/issues"
  },
  "homepage": "https://github.com/WangXueZhi/dev-flow-ai#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "docs",
    "examples/react-vite-dashboard/README.md",
    "examples/react-vite-dashboard/docs",
    "examples/react-vite-dashboard/fixtures",
    "examples/react-vite-dashboard/index.html",
    "examples/react-vite-dashboard/package-lock.json",
    "examples/react-vite-dashboard/package.json",
    "examples/react-vite-dashboard/src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "scripts/example-delivery-smoke.mjs",
    "scripts/live-provider-smoke.mjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test && npm run check:action && npm run check:package",
    "check:action": "node scripts/validate-action.mjs",
    "check:package": "node scripts/validate-package.mjs",
    "dev": "tsx src/cli.ts",
    "example:smoke": "node scripts/example-delivery-smoke.mjs",
    "pack:dry-run": "npm run check:package",
    "pack:smoke": "node scripts/smoke-pack.mjs",
    "smoke:live": "node scripts/live-provider-smoke.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "keywords": [
    "ai",
    "frontend",
    "agent",
    "workflow",
    "codegen",
    "delivery"
  ],
  "author": "DevFlow contributors",
  "license": "MIT",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.9.0"
  }
}
